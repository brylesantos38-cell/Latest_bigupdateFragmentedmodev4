task.spawn(function()
    local function createEpicCaption(mainText, subText, duration)
        local capScr = Instance.new("ScreenGui")
        capScr.Name = "EpicModCaption"
        capScr.ResetOnSpawn = false
        capScr.Parent = p_Gui

        local container = Instance.new("Frame")
        container.Size = UDim2.new(1, 0, 0, 120)
        container.Position = UDim2.new(0, 0, 0.75, 0)
        container.BackgroundTransparency = 1
        container.Parent = capScr

        local mainLbl = Instance.new("TextLabel")
        mainLbl.Size = UDim2.new(1, 0, 0, 50)
        mainLbl.BackgroundTransparency = 1
        mainLbl.TextColor3 = Color3.fromRGB(255, 40, 40)
        mainLbl.TextSize = 36
