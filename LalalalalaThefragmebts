-- GUIDING LIGHT HOOKS SETUP ON DEATH
local function hookGuidingLightSounds()
    pcall(function()
        for _, desc in pairs(workspace:GetDescendants()) do
            if desc:IsA("Folder") and (desc.Name == "Guidelight" or desc.Name == "GuidingLight") then
                for _, snd in pairs(desc:GetDescendants()) do
                    if snd:IsA("Sound") then
                        snd.SoundId = "https://pastebin.com/raw/tLrtSaHh"
                    end
                end
            end
        end
    end)
end

local function watchHumanoid(char)
    local hum = char:WaitForChild("Humanoid", 10)
    if hum then
        hum.Died:Connect(function()
            task.wait(0.5)
            hookGuidingLightSounds()
        end)
    end
end

