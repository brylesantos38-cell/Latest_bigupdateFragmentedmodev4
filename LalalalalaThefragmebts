        subLbl.TextSize = 18
        subLbl.Font = Enum.Font.SourceSansItalic
        subLbl.Text = subText
        subLbl.TextTransparency = 1
        subLbl.Parent = container

        local ti = TweenInfo.new(0.6, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
