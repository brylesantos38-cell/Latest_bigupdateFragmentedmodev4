    createEpicCaption("The Creators", "Credits to Nautic, Jabiss, Noah, and Vynixu", 2.5)
    createEpicCaption("Entity Architect Credits", "Custom entities built by Eoyoustme & Thanhphok", 2.5)
    task.wait(0.5)
    G_Mod.caption("Have fun!", true)
end)

