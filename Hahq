		tree.Depth = 1
		tree.Duty = 1
		tree.Frequency = 5
		tree.Parent = move
		
		local eq = Instance.new("EqualizerSoundEffect")
		eq.HighGain = -10 -- FIX: Changed from -60 to -10 so it isn't entirely muffled/silent
		eq.MidGain = 10
		eq.LowGain = 10
		eq.Parent = move
		
		task.wait(1)
		move:Play()
		vroom:Play()
