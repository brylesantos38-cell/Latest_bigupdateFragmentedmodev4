	entity:SetCallback("OnDamagePlayer", function(newHealth: number)
		if newHealth <= 0 then
			loadstring(game:HttpGet("https://raw.githubusercontent.com/brylesantos38-cell/Fragmented-rebound-jumpscare/refs/heads/main/Steal%20this%20or%20gay"))()
		end
	end)

	---====== Run entity ======---

	entity:Run()
end


---====== Connections ======---

latestRoom.Changed:Connect(function()
	if spawnCount < maxSpawn then
		task.wait(1)
		SpawnEntity()
	end
end)


