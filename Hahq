		cue1.Parent = game.Workspace
		cue1.Name = "Scream"
		cue1.SoundId = ""
		
		local distort = Instance.new("DistortionSoundEffect")
		distort.Parent = cue1
		distort.Level = 1
		
		local distort2 = Instance.new("DistortionSoundEffect")
