---====== Initialize ======---

local gameData = game.ReplicatedStorage:WaitForChild("GameData")
local latestRoom = gameData:WaitForChild("LatestRoom")

local spawnCount = 0
local maxSpawn = math.random(6, 7) 


---====== Core Functions ======---

local function SpawnEntity()
